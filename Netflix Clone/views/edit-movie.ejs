<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Edit Movie</title>
  <link rel="icon" type="image/png" href="/assets/image/logo/favicon.png">
  <link rel="stylesheet" href="/assets/css/add-movie.css" />
</head>
<body>
  <%- include('header') -%>
  <div class="form-wrapper">
    <div class="form-card">
      <h1> Edit Movie</h1>
      <form action="/api/movies/update/<%= movie._id %>" method="POST" enctype="multipart/form-data">

        <div class="form-section">
          <h3>Basic Info</h3>

          <div class="grid-2">
            <div class="form-group">
              <label>Title</label>
              <input type="text" name="title" value="<%= movie.title %>" required />
            </div>

            <div class="form-group">
              <label>Release Year</label>
              <input type="number" name="year" value="<%= movie.year %>" required />
            </div>
          </div>

          <div class="grid-2">
            <div class="form-group">
              <label>Genre</label>
              <input type="text" name="genre" value="<%= movie.genre %>" required />
            </div>

            <div class="form-group">
              <label>Director</label>
              <input type="text" name="director" value="<%= movie.director %>" required />
            </div>
          </div>
        </div>

        <div class="form-section">
          <h3>Details</h3>

          <div class="grid-2">
            <div class="form-group">
              <label>Rating</label>
              <input type="number" step="0.1" name="rating" min="0" max="10" value="<%= movie.rating %>" />
            </div>

            <div class="form-group">
              <label>Duration (min)</label>
              <input type="number" name="duration" value="<%= movie.duration %>" />
            </div>
          </div>
        </div>

        <div class="form-section">
          <h3>Media</h3>

          <div class="form-group">
            <label>Current Poster</label><br/>
            <img src="<%= movie.poster %>" width="120" style="border-radius:8px;" />
          </div>

          <div class="form-group">
            <label>Change Poster</label>
            <input type="file" name="poster" accept="image/*" />
          </div>

          <div class="form-group">
            <label>Description</label>
            <textarea name="description" rows="4"><%= movie.description %></textarea>
          </div>
        </div>

        <button class="submit-btn">Update Movie</button>
      </form>
    </div>
  </div>
  <%- include('footer.ejs') -%>
</body>
</html>